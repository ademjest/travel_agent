QQ_BOT_APPID=replace_with_your_appid
QQ_BOT_SECRET=replace_with_your_appsecret

# Required for production. Empty means no QQ official group is allowed.
QQ_BOT_ALLOWED_GROUPS=
# Development-only override. Keep false in production.
QQ_BOT_ALLOW_ALL_GROUPS=false

# Create a Web Service API key at https://console.amap.com/dev/key/app
AMAP_API_KEY=replace_with_your_amap_web_service_key

# OpenAI-compatible LLM endpoint with native tool-calling support.
LLM_API_KEY=replace_with_your_llm_api_key
LLM_BASE_URL=https://your-provider.example/v1
LLM_MODEL_ID=replace_with_your_model_id
# Optional NapCat/OneBot adapter. Both tokens are required when enabled.
ONEBOT_HTTP_URL=http://127.0.0.1:3000
ONEBOT_ACCESS_TOKEN=
ONEBOT_INBOUND_TOKEN=
ONEBOT_ALLOWED_GROUPS=
ONEBOT_BIND_HOST=127.0.0.1
ONEBOT_BIND_PORT=8000

# Retention. RETENTION_DOCUMENT_DAYS=0 keeps documents indefinitely.
RETENTION_CHAT_DAYS=30
RETENTION_EVENT_DAYS=30
RETENTION_BINDING_DAYS=7
RETENTION_RESERVATION_DAYS=90
RETENTION_IMAGE_DAYS=90
RETENTION_DOCUMENT_DAYS=0
